# Supabase — von https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Postgres-Connection für Drizzle (Migrations + Queries)
# Aus Supabase: Connect-Button oben rechts → Transaction Pooler (Port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres"
